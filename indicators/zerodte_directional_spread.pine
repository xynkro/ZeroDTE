//@version=6
// =============================================================================
// ZeroDTE — BACKEND MIRROR (directional 0DTE credit spread)
// =============================================================================
// This indicator is a FAITHFUL PORT of the backend "boss" (predictor.run_backtest
// + orchestrator confluence/VWAP gates + bs_pricing 30Δ strike placement).
// Goal: whatever the backend tells Telegram, TradingView shows the SAME signal
// and the SAME strike targets. Nothing here is re-invented — every constant
// mirrors backend/app/{predictor.py, config.py, bs_pricing.py, directional_spread_manager.py}.
//
// PARITY SCOPE (per Caspar): the macro-blackout calendar lives in Telegram (it
// tells you when NOT to trade). TradingView's job is the SIGNAL + the STRIKE
// VALUES to target. The only backend input TV cannot see is the Finnhub econ
// calendar; an optional manual "mute" toggle covers known event days.
//
// USE ON: SPX, 5-minute chart, America/New_York. (0DTE same-day expiry.)
// =============================================================================
indicator("ZeroDTE Backend Mirror", overlay=true, max_labels_count=500, max_lines_count=500)

// ── Inputs (defaults == backend LOCKED PARAMETERS) ──────────────────────────
grpSig = "Signal (backend-locked)"
iObsMin       = input.int(15,   "Observation window (min)",        group=grpSig, minval=5)
iVolMult      = input.float(1.5,"Volatile regime mult (obsRange/ATR_D1)", group=grpSig, step=0.1)
iCooldown     = input.int(6,    "Cooldown bars (same direction)",  group=grpSig, minval=0)
iCutoffH      = input.int(14,   "No-new-entry hour (ET)",          group=grpSig)
iCutoffM      = input.int(0,    "No-new-entry minute (ET)",        group=grpSig)
iStochHi      = input.int(80,   "Stoch high thr",                  group=grpSig)
iStochLo      = input.int(20,   "Stoch low thr",                   group=grpSig)
iTrendThr     = input.float(0.05,"Trend EMA-spread thr (%)",       group=grpSig, step=0.01)
iConfMin      = input.int(3,    "Min confluence (of 4)",           group=grpSig, minval=0, maxval=4)
iRsiHi        = input.float(65, "Conf RSI overbought",             group=grpSig)
iRsiLo        = input.float(35, "Conf RSI oversold",               group=grpSig)
iNearEmaPct   = input.float(0.30,"Conf near-EMA10 max ext (%)",    group=grpSig, step=0.01)
iPrimeStartH  = input.int(10,   "Prime start hour (ET)",           group=grpSig)
iPrimeStartM  = input.int(30,   "Prime start min (ET)",            group=grpSig)
iPrimeEndH    = input.int(13,   "Prime end hour (ET)",             group=grpSig)
iPrimeEndM    = input.int(0,    "Prime end min (ET)",              group=grpSig)
iVwapGate     = input.bool(true,"VWAP alignment gate (mandatory)", group=grpSig)
iMuteToday    = input.bool(false,"Macro blackout today (mute signals)", group=grpSig)

grpStk = "Strikes (Black-Scholes 30D)"
iWing         = input.float(10.0,"Wing ($, SPX)",                  group=grpStk)
iPremiumMult  = input.float(1.20,"Premium mult (IV/RV)",           group=grpStk, step=0.05)
iTpPct        = input.float(90,  "TP % of credit",                 group=grpStk)

// ── Normal CDF (Abramowitz & Stegun 7.1.26) — for BS credit only ────────────
ncdf(x) =>
    t = 1.0 / (1.0 + 0.2316419 * math.abs(x))
    dd = 0.3989422804014327 * math.exp(-x * x / 2.0)
    p = dd * t * (0.319381530 + t * (-0.356563782 + t * (1.781477937 + t * (-1.821255978 + t * 1.330274429))))
    x >= 0 ? 1.0 - p : p

callPrice(S, K, tv) =>
    out = 0.0
    if tv <= 0.0
        out := math.max(0.0, S - K)
    else
        d1 = (math.log(S / K) + 0.5 * tv * tv) / tv
        d2 = d1 - tv
        out := S * ncdf(d1) - K * ncdf(d2)
    out

putPrice(S, K, tv) =>
    out = 0.0
    if tv <= 0.0
        out := math.max(0.0, K - S)
    else
        d1 = (math.log(S / K) + 0.5 * tv * tv) / tv
        d2 = d1 - tv
        out := K * ncdf(-d2) - S * ncdf(-d1)
    out

// ── ET clock ────────────────────────────────────────────────────────────────
TZ = "America/New_York"
etH = hour(time, TZ)
etM = minute(time, TZ)
minOfDay = etH * 60 + etM
OPEN_MIN = 9 * 60 + 30                 // 09:30 ET
minsSinceOpen = minOfDay - OPEN_MIN
isRTH = (minOfDay >= OPEN_MIN) and (minOfDay < 16 * 60)

// Session change detector (new ET calendar day OR intraday wrap)
newDay = ta.change(time("D")) != 0
isNewSession = na(minsSinceOpen[1]) ? true : ((minsSinceOpen < minsSinceOpen[1]) or newDay)

// ── Indicators (backend-exact) ──────────────────────────────────────────────
rsi   = ta.rsi(close, 14)
k     = ta.stoch(close, high, low, 14)
d     = ta.sma(k, 3)
ema10 = ta.ema(close, 10)
ema30 = ta.ema(close, 30)

// Prior-day ATR(14) on the Daily timeframe (no lookahead) — regime input
atrD1 = request.security(syminfo.tickerid, "D", ta.atr(14)[1], lookahead=barmerge.lookahead_off)

// Williams VIX Fix (period 22, 2-sigma BB band — backend uses population sigma)
hc22     = ta.highest(close, 22)
wvf      = (hc22 - low) / hc22 * 100.0
wvfMid   = ta.sma(wvf, 22)
wvfSd    = ta.stdev(wvf, 22, true)                      // biased=true == population (ddof=0)
wvfSpike = wvf > (wvfMid + 2.0 * wvfSd)

// EMA-spread trend (counter-trend suppression)
spreadPct = (ema10 - ema30) / ema30 * 100.0
trendUp   = spreadPct >  iTrendThr
trendDown = spreadPct < -iTrendThr

// ── Observation window + volatile-regime lock (per session) ─────────────────
var float obsHigh = na
var float obsLow  = na
var bool  obsDone = false
var bool  isVolatile = false
if isNewSession
    obsHigh := na
    obsLow  := na
    obsDone := false
    isVolatile := false
inObs = isRTH and (minsSinceOpen < iObsMin)
if inObs
    obsHigh := na(obsHigh) ? high : math.max(obsHigh, high)
    obsLow  := na(obsLow)  ? low  : math.min(obsLow,  low)
// First post-obs bar: finalize regime once.
if isRTH and (minsSinceOpen >= iObsMin) and (not obsDone) and (not na(obsHigh)) and (not na(atrD1)) and atrD1 > 0
    obsRange = obsHigh - obsLow
    isVolatile := (obsRange / atrD1) > iVolMult
    obsDone := true

// ── Session-anchored VWAP + realized 5m vol ─────────────────────────────────
// VWAP mirrors backend _compute_session_vwap EXACTLY: typical = HLC3, weight =
// max(volume or 1, 1). SPX index has no volume → weight=1 → cumulative HLC3 mean
// (TWAP). realized_std mirrors _session_realized_std (>=5 session closes).
var float sSum   = 0.0
var float sSumSq = 0.0
var int   sN     = 0
var int   rthBar = 0
var float cumPV  = 0.0
var float cumV   = 0.0
if isNewSession
    sSum := 0.0
    sSumSq := 0.0
    sN := 0
    rthBar := 0
    cumPV := 0.0
    cumV := 0.0
if isRTH
    rthBar += 1
    typ = (high + low + close) / 3.0
    wv = math.max(nz(volume, 1), 1)
    cumPV += typ * wv
    cumV  += wv
    if rthBar >= 2 and close[1] > 0 and close > 0          // skip overnight gap
        lr = math.log(close / close[1])
        sSum   += lr
        sSumSq += lr * lr
        sN     += 1
vwap = cumV > 0 ? cumPV / cumV : na
realizedStd = (rthBar >= 5 and sN >= 2) ? math.sqrt((sSumSq - sSum * sSum / sN) / (sN - 1)) : na

// ── Raw trigger: stochastic reversal cross (backend run_backtest) ───────────
crossDownFromHigh = (k[1] > d[1]) and (k < d) and (k[1] > iStochHi)   // -> SELL CALL
crossUpFromLow    = (k[1] < d[1]) and (k > d) and (k[1] < iStochLo)   // -> SELL PUT

cutoffMin = iCutoffH * 60 + iCutoffM
afterCutoff = minOfDay >= cutoffMin

// Cooldown (bars since last same-direction signal)
var int lastCallBar = na
var int lastPutBar  = na
callCoolOk = na(lastCallBar) or (bar_index - lastCallBar) >= iCooldown
putCoolOk  = na(lastPutBar)  or (bar_index - lastPutBar)  >= iCooldown

postObs = isRTH and (minsSinceOpen >= iObsMin)

// ── Confluence (4 scored quality factors; macro/VIX are gates in backend) ───
inPrime = (minOfDay >= (iPrimeStartH * 60 + iPrimeStartM)) and (minOfDay <= (iPrimeEndH * 60 + iPrimeEndM))
nearEma = (math.abs(close - ema10) / close * 100.0) < iNearEmaPct

confCall = (rsi > iRsiHi ? 1 : 0) + (wvfSpike ? 1 : 0) + (nearEma ? 1 : 0) + (inPrime ? 1 : 0)
confPut  = (rsi < iRsiLo ? 1 : 0) + (wvfSpike ? 1 : 0) + (nearEma ? 1 : 0) + (inPrime ? 1 : 0)

// Failsafe-open when VWAP unavailable — matches backend _check_vwap_for_side.
vwapCallOk = (not iVwapGate) or na(vwap) or (close > vwap)
vwapPutOk  = (not iVwapGate) or na(vwap) or (close < vwap)

// ── Full signal stack (mirrors what the boss actually FIRES -> Telegram) ────
baseOk = postObs and (not isVolatile) and (not afterCutoff) and (not iMuteToday)
fireCall = baseOk and crossDownFromHigh and callCoolOk and (not trendUp)   and (confCall >= iConfMin) and vwapCallOk
firePut  = baseOk and crossUpFromLow    and putCoolOk  and (not trendDown) and (confPut  >= iConfMin) and vwapPutOk
if fireCall
    lastCallBar := bar_index
if firePut
    lastPutBar := bar_index

// ── Strike placement: Black-Scholes 30D (closed form) + credit ──────────────
Z30 = 0.5244005127416016                                  // |inverseNormal(0.30)|
periodsLeft = math.max((16 * 60) - minOfDay, 0) / 5.0
tv0 = na(realizedStd) ? na : realizedStd * math.sqrt(periodsLeft) * iPremiumMult

// ── Plot signals + strike targets ───────────────────────────────────────────
plotSignal(isCall) =>
    S = close
    haveVol = (not na(tv0)) and tv0 > 0
    float sk = na
    float lk = na
    float creditUsd = na
    if haveVol
        sk := isCall ? S * math.exp(0.5 * tv0 * tv0 + Z30 * tv0) : S * math.exp(0.5 * tv0 * tv0 - Z30 * tv0)
        lk := isCall ? sk + iWing : sk - iWing
        cps = isCall ? math.max(0.0, callPrice(S, sk, tv0) - callPrice(S, lk, tv0)) : math.max(0.0, putPrice(S, sk, tv0) - putPrice(S, lk, tv0))
        creditUsd := cps * 100.0
    else
        sk := isCall ? S * (1 + 0.35 / 100.0) : S * (1 - 0.35 / 100.0)   // fallback: 30D ~ 0.35% OTM
        lk := isCall ? sk + iWing : sk - iWing
    tpBuyback = na(creditUsd) ? na : creditUsd * (1 - iTpPct / 100.0)
    col = isCall ? color.new(color.red, 0) : color.new(color.green, 0)
    txt = (isCall ? "SELL CALL" : "SELL PUT") + "\nshort " + str.tostring(sk, "#.##") + " / long " + str.tostring(lk, "#.##") + (na(creditUsd) ? "\ncredit n/a (warming)" : "\nest credit $" + str.tostring(creditUsd, "#") + "\nTP " + str.tostring(iTpPct, "#") + "% (buy back ~$" + str.tostring(tpBuyback, "#") + ")\nSL ~-$" + str.tostring(creditUsd, "#") + " (spread 2x) T-30m")
    label.new(bar_index, isCall ? high : low, txt, style=isCall ? label.style_label_down : label.style_label_up, color=col, textcolor=color.white, size=size.small, yloc=isCall ? yloc.abovebar : yloc.belowbar)
    line.new(bar_index, sk, bar_index + 12, sk, color=col, width=2, style=line.style_solid)
    line.new(bar_index, lk, bar_index + 12, lk, color=color.new(col, 55), width=1, style=line.style_dashed)

if fireCall
    plotSignal(true)
if firePut
    plotSignal(false)

// ── Visual context ──────────────────────────────────────────────────────────
plot(vwap, "VWAP", color=color.new(color.orange, 30))
plot(ema10, "EMA10", color=color.new(color.aqua, 40))
plot(ema30, "EMA30", color=color.new(color.blue, 40))
bgcolor(isVolatile and isRTH ? color.new(color.gray, 88) : na, title="Volatile regime (stand aside)")
plotshape(fireCall, "Sell Call", shape.triangledown, location.abovebar, color.red,  size=size.tiny)
plotshape(firePut,  "Sell Put",  shape.triangleup,   location.belowbar, color.green, size=size.tiny)

// ── Alerts (so a TV alert can mirror Telegram) ──────────────────────────────
alertcondition(fireCall, "ZeroDTE SELL CALL", "ZeroDTE SELL CALL signal")
alertcondition(firePut,  "ZeroDTE SELL PUT",  "ZeroDTE SELL PUT signal")
