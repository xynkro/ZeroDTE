# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Finnhub (macro news + economic calendar) ---
# Free tier: 60 calls/min. Get key at https://finnhub.io/dashboard
FINNHUB_API_KEY=

# --- IBKR TWS (local connection; paper = 7497, live = 7496) ---
# Requires TWS or IB Gateway running with API access enabled
# (TWS: File → Global Configuration → API → Settings → Enable ActiveX and Socket Clients)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=42

# --- Risk controls (HARD limits enforced by orchestrator) ---
DAILY_LOSS_LIMIT_PCT=2.0
MAX_TRADES_PER_DAY=4
MAX_CONCURRENT_POSITIONS=3
TRADING_ENABLED=false
SHADOW_MODE=true
SIZE_CAP_USD=500

# --- Backend server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765
FRONTEND_ORIGIN=http://localhost:5179
